---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const projects = [
  {
    index: '№ 01',
    title: 'Lineup',
    description: 'Concert discovery iOS app on a production data platform. 1M+ events and 300K+ artists ingested daily from six APIs via Airflow; BigQuery + dbt; 122 unit tests; zero data losses in twelve months.',
    href: '/projects/lineup',
    tags: ['iOS', 'Airflow', 'BigQuery', 'dbt'],
    status: 'Production · 2024–',
  },
  {
    index: '№ 02',
    title: 'NutriPlan',
    description: 'AI meal planner. FastAPI + GPT-4o with pgvector RAG, calorie accuracy within ±10%, generation under two seconds end-to-end, 99.8% uptime on Render. SwiftUI frontend in beta.',
    href: '/projects/nutriplan',
    tags: ['iOS', 'FastAPI', 'RAG', 'pgvector'],
    status: 'Beta · 2025–',
  },
  {
    index: '№ 03',
    title: 'JobHunter',
    description: 'My own job search automation. Claude API scores 500 to 1,000 jobs a day against a six-dimension career framework. Playwright crawlers across four sources, GitHub Actions cron, Notion as the UI.',
    href: '/projects/jobhunter',
    tags: ['Python', 'Claude API', 'Playwright', 'Notion'],
    status: 'In daily use · 2026',
  },
  {
    index: '№ 04',
    title: 'Earnings Call Analyser',
    description: 'PyTorch + FinBERT NLP pipeline testing Chiang et al. 2025 on earnings call Q&A alignment as an equity signal. Contrastive classifier, backtesting framework, Kubernetes deployment. Started Q1 2026.',
    href: '/projects/earnings-call-analyser',
    tags: ['PyTorch', 'FinBERT', 'NLP', 'Research'],
    status: 'Proof of concept · Q1 2026',
  },
];
---

<BaseLayout
  title="Field Notes · Projects · Jevan Cousins"
  description="A selection of projects, from production data platforms to earlier-stage research. Each entry is a working system documented as a case study."
>
  <article class="max-w-[1280px] mx-auto px-6 md:px-10 pt-10 pb-24">

    <div class="flex items-center justify-between border-y border-ink py-2 mb-12 mono text-[0.68rem] uppercase tracking-widest text-ink">
      <span>Projects</span>
      <span class="text-ink-muted hidden md:inline">Working systems, decisions, trade-offs</span>
      <span>Folio · I</span>
    </div>

    <header class="grid grid-cols-12 gap-6 mb-16">
      <div class="col-span-12 md:col-span-9">
        <p class="label-oxide mb-5">An index, in four parts</p>
        <h1 class="font-display leading-[0.96] text-ink mb-6">
          Field<br/>
          <span class="italic text-oxide">notes.</span>
        </h1>
      </div>
      <aside class="col-span-12 md:col-span-3 md:pl-6 md:border-l border-rule self-end">
        <p class="font-display italic text-xl text-ink leading-snug mb-3">
          Four projects. Each one a system somebody depends on, including me.
        </p>
        <p class="mono text-[0.7rem] uppercase tracking-widest text-ink-muted">
          Case studies focus on the decisions, not the highlight reel.
        </p>
      </aside>
    </header>

    <hr class="rule mb-2" />
    <div class="flex justify-between mono text-[0.66rem] uppercase tracking-widest text-ink-muted py-2">
      <span>Entry</span>
      <span class="hidden md:inline">Notes</span>
      <span>Action</span>
    </div>

    <div>
      {projects.map((p) => (
        <ProjectCard
          title={p.title}
          description={p.description}
          href={p.href}
          tags={p.tags}
          status={p.status}
          index={p.index}
        />
      ))}
      <div class="border-t border-ink"></div>
    </div>

    <p class="mono text-[0.7rem] uppercase tracking-widest text-ink-faint mt-8">
      End of folio · Four entries · Filed and current.
    </p>
  </article>
</BaseLayout>
