---
interface Props {
  title: string;
  description: string;
  href: string;
  tags?: string[];
  status?: string;
}

const { title, description, href, tags = [], status } = Astro.props;
---

<a
  href={href}
  class="group block p-6 border border-border-subtle rounded-lg hover:border-accent-red transition-all duration-200 hover:shadow-lg hover:-translate-y-1"
>
  <div class="mb-4">
    <div class="flex items-baseline justify-between mb-2 gap-3">
      <h3 class="text-xl font-display font-semibold group-hover:text-accent-red transition-colors">
        {title}
      </h3>
      {status && (
        <span class="text-[0.65rem] uppercase tracking-wider text-accent-red/80 font-medium whitespace-nowrap">
          {status}
        </span>
      )}
    </div>
    <p class="text-text-muted text-sm leading-relaxed">
      {description}
    </p>
  </div>

  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2 pt-4 border-t border-border-subtle">
      {tags.map((tag) => (
        <span class="text-xs px-2 py-1 bg-border-subtle text-text-muted rounded">
          {tag}
        </span>
      ))}
    </div>
  )}
</a>
