---
interface Props {
  title: string;
  description: string;
  href: string;
  tags?: string[];
  status?: string;
  index?: string;
  meta?: string;
}

const { title, description, href, tags = [], status, index, meta } = Astro.props;
---

<a
  href={href}
  class="group block border-t border-ink pt-6 pb-7 transition-colors duration-200 hover:bg-paper-shade -mx-3 px-3"
>
  <div class="flex items-baseline justify-between gap-4 mb-2">
    <div class="flex items-baseline gap-3 min-w-0">
      {index && (
        <span class="mono text-[0.7rem] uppercase tracking-widest text-oxide flex-none">
          {index}
        </span>
      )}
      <h3 class="font-display text-3xl md:text-4xl leading-none text-ink truncate group-hover:italic transition-all">
        {title}
      </h3>
    </div>
    {status && (
      <span class="mono text-[0.62rem] uppercase tracking-widest text-ink-muted flex-none whitespace-nowrap">
        · {status}
      </span>
    )}
  </div>

  <p class="text-ink-muted leading-snug max-w-2xl mb-3">
    {description}
  </p>

  <div class="flex items-center justify-between flex-wrap gap-3">
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-x-3 gap-y-1 mono text-[0.65rem] uppercase tracking-widest text-ink-muted">
        {tags.map((tag, i) => (
          <span>
            {tag}{i < tags.length - 1 ? '' : ''}
          </span>
        ))}
      </div>
    )}
    <span class="mono text-[0.7rem] uppercase tracking-widest text-ink group-hover:text-oxide transition-colors">
      {meta ?? 'Read the dossier'} →
    </span>
  </div>
</a>
