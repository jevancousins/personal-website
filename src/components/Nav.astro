---
const currentPath = new URL(Astro.request.url).pathname;

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Papers', href: '/papers' },
  { label: 'Notes', href: '/notes' },
  { label: 'Reading', href: '/reading' },
  { label: 'Journal', href: '/journal' },
  { label: 'About', href: '/about' },
];

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="sticky top-0 z-40 bg-paper/95 backdrop-blur-[2px] border-b border-ink">
  <div class="max-w-[1320px] mx-auto px-5 md:px-9">
    <div class="flex items-center justify-between gap-6 py-3">
      <a href="/" class="flex items-center gap-3 group min-w-0">
        <span class="inline-flex items-center justify-center w-7 h-7 border border-ink text-ink font-display text-sm leading-none group-hover:bg-ink group-hover:text-paper transition-colors flex-none font-semibold">
          jc
        </span>
        <span class="hidden md:inline sans text-[0.66rem] tracking-[0.18em] uppercase text-ink-muted truncate">
          A working journal of applied engineering · Vol. 04
        </span>
        <span class="md:hidden sans text-[0.62rem] tracking-[0.18em] uppercase text-ink-muted truncate">
          J. Cousins · Vol. 04
        </span>
      </a>

      <nav class="flex items-center gap-4 md:gap-6 flex-none">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`nav-link sans text-[0.7rem] tracking-[0.16em] uppercase font-medium ${
              isActive(item.href) ? 'text-prussian' : 'text-ink hover:text-prussian'
            }`}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>
