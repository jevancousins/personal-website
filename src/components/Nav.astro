---
const currentPath = new URL(Astro.request.url).pathname;

const navItems = [
  { label: 'Index', href: '/' },
  { label: 'Field Notes', href: '/projects' },
  { label: 'Now', href: '/now' },
  { label: 'Writing', href: '/writing' },
  { label: 'Bio', href: '/about' },
];

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="sticky top-0 z-40 bg-paper/90 backdrop-blur-[2px] border-b border-rule">
  <div class="max-w-[1280px] mx-auto px-6 md:px-10">
    <div class="grid grid-cols-12 gap-6 items-center py-3">
      <a href="/" class="col-span-3 md:col-span-2 flex items-center gap-3 group">
        <span class="inline-flex items-center justify-center w-8 h-8 border border-ink text-ink font-display text-lg leading-none group-hover:bg-ink group-hover:text-paper transition-colors">
          JC
        </span>
        <span class="hidden md:inline mono text-[0.68rem] tracking-widest uppercase text-ink-muted">
          Dossier № 04
        </span>
      </a>

      <nav class="col-span-9 md:col-span-10 flex items-center justify-end gap-5 md:gap-8">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`nav-link mono text-[0.7rem] tracking-widest uppercase ${
              isActive(item.href) ? 'text-oxide' : 'text-ink hover:text-oxide'
            }`}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>
