---
const currentYear = new Date().getFullYear();
const buildDate = new Date().toISOString().slice(0, 10);
---

<footer class="border-t border-ink mt-24 bg-paper">
  <div class="max-w-[1320px] mx-auto px-5 md:px-9 py-12">
    <div class="grid grid-cols-12 gap-6 items-start">

      <div class="col-span-12 md:col-span-5">
        <p class="label-prussian mb-3">Correspondence</p>
        <p class="font-display text-[1.7rem] md:text-[2rem] leading-[1.15] text-ink mb-3">
          For collaborations, conversations, or quiet introductions.
        </p>
        <p class="text-ink-muted text-[0.95rem] max-w-md leading-relaxed">
          I read every message and reply to most. Bien à vous.
        </p>
        <a
          href="mailto:jevan.cousins@gmail.com"
          class="ink-link sans text-[0.74rem] tracking-[0.18em] uppercase font-medium mt-4 inline-block"
        >
          jevan.cousins@gmail.com →
        </a>
      </div>

      <div class="col-span-6 md:col-span-3 md:col-start-7">
        <p class="label mb-3">Index</p>
        <ul class="space-y-2 sans text-[0.78rem]">
          <li><a href="/papers" class="nav-link text-ink hover:text-prussian">Papers</a></li>
          <li><a href="/notes" class="nav-link text-ink hover:text-prussian">Notes</a></li>
          <li><a href="/reading" class="nav-link text-ink hover:text-prussian">Reading</a></li>
          <li><a href="/journal" class="nav-link text-ink hover:text-prussian">Lab journal</a></li>
          <li><a href="/about" class="nav-link text-ink hover:text-prussian">About</a></li>
        </ul>
      </div>

      <div class="col-span-6 md:col-span-3">
        <p class="label mb-3">Elsewhere</p>
        <ul class="space-y-2 sans text-[0.78rem]">
          <li>
            <a href="https://github.com/jevancousins" target="_blank" rel="noopener noreferrer" class="nav-link text-ink hover:text-prussian">
              GitHub ↗
            </a>
          </li>
          <li>
            <a href="https://linkedin.com/in/jevancousins" target="_blank" rel="noopener noreferrer" class="nav-link text-ink hover:text-prussian">
              LinkedIn ↗
            </a>
          </li>
        </ul>
      </div>
    </div>

    <hr class="rule mt-12 mb-3" />

    <div class="flex flex-wrap items-end justify-between gap-3 sans text-[0.66rem] uppercase tracking-[0.18em] text-ink-faint">
      <span>© {currentYear} J. Cousins · London</span>
      <span class="mono normal-case tracking-[0.04em] text-[0.7rem]">
        Set in Source Serif 4, IBM Plex Sans, IBM Plex Mono · Built with Astro · Edition {currentYear} · Build {buildDate}
      </span>
    </div>
  </div>
</footer>
