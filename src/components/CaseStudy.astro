---
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  subtitle?: string;
  description?: string;
}

const { title, subtitle, description } = Astro.props;
---

<article class="max-w-3xl mx-auto px-6 py-16">
  <header class="mb-12">
    <p class="text-accent-red font-medium text-sm mb-4">Case Study</p>
    <h1 class="font-display font-bold mb-4">{title}</h1>
    {subtitle && <p class="text-lg text-text-muted">{subtitle}</p>}
    {description && <p class="text-text-muted mt-4">{description}</p>}
  </header>

  <div class="prose prose-invert max-w-none">
    <slot />
  </div>
</article>
