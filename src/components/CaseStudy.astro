---
interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  status?: string;
  meta?: { label: string; value: string }[];
  repo?: string;
}

const { title, subtitle, description, status, meta = [], repo } = Astro.props;
---

<article class="max-w-[1280px] mx-auto px-6 md:px-10 pt-10 pb-20">
  <!-- Document header band -->
  <div class="flex items-center justify-between border-y border-ink py-2 mb-12 mono text-[0.68rem] uppercase tracking-widest text-ink">
    <span>Field Note</span>
    <span class="text-ink-muted hidden md:inline">A study in shipping</span>
    <span>{status ?? 'Filed'}</span>
  </div>

  <header class="grid grid-cols-12 gap-6 mb-16">
    <div class="col-span-12 md:col-span-8">
      <p class="label-oxide mb-5">Case Study</p>
      <h1 class="font-display text-ink leading-[0.96] mb-6 text-[clamp(3rem,9vw,6.5rem)]">
        {title}
      </h1>
      {subtitle && (
        <p class="font-display italic text-2xl md:text-3xl text-ink-muted leading-tight max-w-2xl">
          {subtitle}
        </p>
      )}
      {description && (
        <p class="text-ink-muted mt-5 max-w-2xl leading-relaxed">
          {description}
        </p>
      )}
    </div>

    <aside class="col-span-12 md:col-span-4 md:pl-8 md:border-l border-rule">
      <p class="label mb-4">Meta</p>
      <dl class="space-y-3 mono text-[0.78rem]">
        {meta.map((m) => (
          <div class="flex justify-between gap-4 border-b border-rule pb-2">
            <dt class="text-ink-muted uppercase tracking-widest text-[0.66rem]">{m.label}</dt>
            <dd class="text-ink text-right">{m.value}</dd>
          </div>
        ))}
      </dl>
      {repo && (
        <a
          href={repo}
          target="_blank"
          rel="noopener noreferrer"
          class="ink-link mono text-[0.72rem] uppercase tracking-widest mt-6 inline-block"
        >
          GitHub repository ↗
        </a>
      )}
    </aside>
  </header>

  <!-- Content -->
  <div class="grid grid-cols-12 gap-6">
    <div class="col-span-12 md:col-span-8 md:col-start-3">
      <div class="prose-body">
        <slot />
      </div>

      <hr class="rule-double mt-16 mb-8" />

      <div class="flex items-center justify-between mono text-[0.7rem] uppercase tracking-widest text-ink-muted">
        <a href="/projects" class="ink-link text-ink">← All field notes</a>
        <a href="mailto:jevan.cousins@gmail.com" class="ink-link text-ink">Discuss this →</a>
      </div>
    </div>
  </div>
</article>
